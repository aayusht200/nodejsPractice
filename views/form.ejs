<form
    method="POST"
    action="/new"
    style="display: grid; gap: 1rem; border: 1px solid grey; width: max-content; padding: 1rem"
>
    <label for="name">
        Name:
        <input type="text" name="name" id="name" />
    </label>
    <br />
    <label for="message">
        Message:
        <input type="text" name="message" id="message" />
    </label>
    <button type="submit" style="width: fit-content">Submit</button>
</form>
